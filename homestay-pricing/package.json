{
  "name": "homestay-pricing-scraper",
  "version": "1.0.0",
  "description": "民宿竞品数据采集器 - Playwright持久化登录 + 自动采集OTA竞品价格",
  "main": "scripts/scraper.js",
  "scripts": {
    "init": "node scripts/scraper.js init",
    "check": "node scripts/scraper.js check",
