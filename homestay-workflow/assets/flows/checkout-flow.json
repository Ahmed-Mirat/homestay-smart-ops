{
  "name": "退房流程",
  "version": "1.0",
  "description": "客人退房后的标准处理流程",
  "trigger": {
    "dialog": ["退房流程", "今天退房", "客人走了"],
    "cron": "0 10 * * *",
    "event": "checkout_today"
  },
  "condition": {
    "check": "today_has_checkout",
    "dataSource": "_shared/data/orders.json"
  },
  "steps": [
    {
      "id": 1,
      "name": "退房检查",
      "action": "generate_checklist",
      "items": [
        "物品核对：房卡/钥匙/遥控器",
        "设施检查：有无损坏",
        "遗留物品检查",
        "房间整体检视"
      ]
    },
    {
      "id": 2,
      "name": "派发保洁任务",
      "action": "notify",
      "target": "housekeeper",
      "template": "checkout_cleaning",
      "content": "{{roomNumber}} 退房清洁：深度清洁 + 布草更换 + 物品补充 + 垃圾清理"
    },
    {
      "id": 3,
      "name": "等待保洁完成",
      "action": "wait_confirmation",
      "prompt": "保洁完成后请确认",
      "timeout": "4h"
    },
    {
      "id": 4,
      "name": "恢复售卖",
      "action": "call_skill",
      "skill": "homestay-sync",
      "operation": "openRoom",
      "params": {
        "roomType": "{{roomType}}",
        "dates": ["{{today}}", "{{tomorrow}}"]
      },
      "description": "全平台开放售卖"
    },
    {
      "id": 5,
      "name": "归档记录",
      "action": "update_data",
      "target": "_shared/data/orders.json",
      "update": "标记订单为已完成"
    }
  ]
}
